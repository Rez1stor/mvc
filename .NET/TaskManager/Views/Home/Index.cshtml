@model IEnumerable<TaskManager.Models.TaskItem>

@{
    ViewData["Title"] = "Task Manager - .NET";
}

<div class="text-center">
    <h1 class="display-4">Task Manager</h1>
    
    <div class="row mt-4 text-start">
        <div class="col-md-6">
            <h2>Додати нове завдання</h2>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Назва</label>
                    <input name="Title" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Опис</label>
                    <textarea name="Description" class="form-control"></textarea>
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" name="IsCompleted" value="true" class="form-check-input" id="isCompleted" />
                    <input type="hidden" name="IsCompleted" value="false" />
                    <label class="form-check-label" for="isCompleted">Виконано</label>
                </div>
                <button type="submit" class="btn btn-primary">Додати</button>
            </form>
        </div>
        
        <div class="col-md-6">
            <h2>Список завдань</h2>
            <ul class="list-group">
                @if (Model != null && Model.Any())
                {
                    foreach (var task in Model)
                    {
                        <li class="list-group-item">
                            <strong>@task.Title</strong> - 
                            @if (task.IsCompleted)
                            {
                                <span class="text-success">Виконано</span>
                            }
                            else
                            {
                                <span class="text-danger">Не виконано</span>
                            }
                            <p class="mb-0 text-muted">@task.Description</p>
                            <small>@task.CreatedAt.ToString("g")</small>
                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item">Немає завдань.</li>
                }
            </ul>
        </div>
    </div>
</div>
